model FeeCategory {
  id            String         @id @default(uuid())
  schoolId      String
  name          String
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  school        School         @relation(fields: [schoolId], references: [id])
  feeStructures FeeStructure[]

  @@unique([schoolId, name])
}

model FeeStructure {
  id             String           @id @default(uuid())
  schoolId       String
  academicYearId String
  classId        String
  feeCategoryId  String
  amount         Decimal          @db.Decimal(10, 2)
  discount       Decimal?         @db.Decimal(10, 2)
  lateFee        Decimal?         @db.Decimal(10, 2)
  dueDate        DateTime?
  frequency      FeeFrequency
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  class          Class            @relation(fields: [classId], references: [id])
  feeCategory    FeeCategory      @relation(fields: [feeCategoryId], references: [id])
  school         School           @relation(fields: [schoolId], references: [id])
  invoices       StudentInvoice[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([classId])
}

model StudentInvoice {
  id             String        @id @default(uuid())
  receiptNo      String        @unique
  schoolId       String
  studentId      String
  feeStructureId String
  amount         Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  lateFee        Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING)
  issuedAt       DateTime      @default(now())
  dueDate        DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  payment        Payment?
  feeStructure   FeeStructure  @relation(fields: [feeStructureId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([paymentStatus])
  @@index([schoolId])
}

model Payment {
  id            String         @id @default(uuid())
  schoolId      String
  invoiceId     String         @unique
  paymentMethod PaymentMethod
  paidAmount    Decimal        @db.Decimal(10, 2)
  paidAt        DateTime       @default(now())
  transactionId String?
  remarks       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  invoice       StudentInvoice @relation(fields: [invoiceId], references: [id])
  school        School         @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([paidAt])
}
